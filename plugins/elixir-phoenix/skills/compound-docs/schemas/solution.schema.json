{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compound Solution Document",
  "description": "Schema for solution documentation YAML frontmatter in .claude/solutions/",
  "type": "object",
  "required": ["module", "date", "problem_type", "component", "symptoms", "root_cause", "severity", "tags"],
  "properties": {
    "module": {
      "type": "string",
      "description": "Elixir module or context area",
      "examples": ["Accounts", "LiveView.UserList", "Workers.EmailSender"]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in YYYY-MM-DD format"
    },
    "problem_type": {
      "type": "string",
      "description": "Category of the problem",
      "enum": [
        "build_error", "test_failure", "runtime_error",
        "performance_issue", "database_issue", "security_issue",
        "liveview_bug", "oban_issue", "otp_issue",
        "integration_issue", "logic_error", "deployment_issue",
        "iron_law_violation"
      ]
    },
    "component": {
      "type": "string",
      "description": "Which component area was affected"
    },
    "symptoms": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 5,
      "description": "Observable symptoms — error messages, visual issues, unexpected behavior"
    },
    "root_cause": {
      "type": "string",
      "description": "The actual underlying reason WHY this happened"
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "maxItems": 8,
      "description": "Searchable keywords, lowercase, hyphen-separated"
    },
    "elixir_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "phoenix_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "iron_law_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 22
    },
    "related_solutions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
